# macOS
.DS_Store

# pixi environments
.pixi/*
!.pixi/config.toml
*.lock

# Build outputs
build/
target/

# Cloned simdjson (built via `pixi run build`)
src/simdjson_ffi/simdjson/

# Mojo cache
__pycache__/
*.mojopkg

.cursor/
.agents/

# Large benchmark datasets (download from cuJSON Google Drive)
benchmark/datasets/twitter_large_record.json
benchmark/datasets/walmart_large_record.json
benchmark/datasets/wiki_large_record.json

# cuJSON (download on-demand for NVIDIA GPU benchmarks)
benchmark/cuJSON/

# build directories
build/

# Example output files
output.json
config.json
counter.json
gpu_test.json

# build artifacts
json-*

# Mozz fuzzing artifacts. The corpus directory is created lazily by
# each harness (fuzz/corpus/<harness>/seed_NNNN.bin). Treat it as a
# runtime artifact rather than tracked source -- only fuzz/corpus/
# itself + a .gitkeep are committed so the dir always exists.
fuzz/corpus/*
!fuzz/corpus/.gitkeep
.mozz_crashes/

# Sanitizer build / log output
target/sanitize/
